{
  "latex-workshop.latex.env": {
    "TEXINPUTS": "..;"
  },
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "%DIR%/%DOCFILE%.tex"
      ],
      "env": {
        "TEXINPUTS": "..;"
      }
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    }
  ]
}
